generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Stock {
  id          Int      @id @default(autoincrement())
  ticker      String   @unique
  name        String
  trend       String
  trendColor  String
  analysis    String
  entryArea   String
  targetPrice String
  stopLoss    String
  type        String   // 'mingguan' or 'bulanan'
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
